{{!< default}}

{{!-- 
    Custom Page Template: Ferramentas
    Use this by selecting "ferramentas" in the page template dropdown in Ghost
--}}

{{#post}}
<article class="post-full page-ferramentas">
    {{!-- Page Header --}}
    <header class="hero" style="min-height: 40vh; padding-top: calc(var(--header-height) + var(--space-8));">
        <div class="hero-background bg-gradient-sunset">
            <div class="stars"></div>
        </div>
        
        <div class="hero-content">
            <span class="post-header-tag" style="margin-bottom: var(--space-4);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display: inline; vertical-align: middle; margin-right: 4px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Ferramentas
            </span>
            <h1 class="hero-title" style="font-size: var(--text-2xl);">{{title}}</h1>
            
            {{#if custom_excerpt}}
            <p class="hero-subtitle">{{custom_excerpt}}</p>
            {{/if}}
        </div>
    </header>
    
    {{!-- Page Content --}}
    <div class="container">
        <section class="post-content gh-content" style="padding-top: var(--space-12);">
            {{content}}
        </section>
        
        {{!-- Related Tools Posts --}}
        {{#get "posts" filter="tag:ferramentas" limit="6"}}
        {{#if posts}}
        <section class="posts-section">
            <header class="section-header">
                <h2 class="section-title">Posts sobre Ferramentas</h2>
                <a href="{{@site.url}}/tag/ferramentas/" class="btn btn-ghost btn-sm">
                    Ver todos
                </a>
            </header>
            
            <div class="post-grid">
                {{#foreach posts}}
                {{> post-card}}
                {{/foreach}}
            </div>
        </section>
        {{/if}}
        {{/get}}
    </div>
</article>
{{/post}}

