{{!< default}}

{{!-- 
    Custom Page Template: Sobre
    Use this by selecting "sobre" in the page template dropdown in Ghost
--}}

{{#post}}
<article class="post-full page-sobre">
    {{!-- Page Header with Charlotte --}}
    <header class="hero" style="min-height: 50vh; padding-top: calc(var(--header-height) + var(--space-8));">
        <div class="hero-background bg-gradient-sunset">
            <div class="stars"></div>
        </div>
        
        <div class="hero-content">
            <h1 class="hero-title" style="font-size: var(--text-2xl);">{{title}}</h1>
            
            {{#if custom_excerpt}}
            <p class="hero-subtitle">{{custom_excerpt}}</p>
            {{else}}
            <p class="hero-subtitle">
                Conheça a GinanRM
            </p>
            {{/if}}
        </div>
    </header>
    
    {{!-- Page Content --}}
    <div class="container">
        <section class="post-content gh-content" style="padding-top: var(--space-12);">
            {{content}}
        </section>
        
        {{!-- Team Section (if you have multiple authors) --}}
        {{#get "authors" limit="20"}}
        {{#if authors.length}}
        <section class="posts-section">
            <header class="section-header">
                <h2 class="section-title">Nossa Equipe</h2>
            </header>
            
            <div class="post-grid" style="grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));">
                {{#foreach authors}}
                <div class="sidebar-widget text-center">
                    {{#if profile_image}}
                    <img 
                        src="{{img_url profile_image size="m"}}" 
                        alt="{{name}}" 
                        style="width: 100px; height: 100px; border-radius: var(--radius-full); object-fit: cover; margin: 0 auto var(--space-4); border: 3px solid var(--lc-neon-cyan);"
                    >
                    {{/if}}
                    <h3 style="font-family: var(--font-heading); margin-bottom: var(--space-2);">
                        <a href="{{url}}" style="color: var(--lc-neon-cyan);">{{name}}</a>
                    </h3>
                    {{#if bio}}
                    <p style="color: var(--lc-gray-400); font-size: var(--text-sm);">
                        {{bio}}
                    </p>
                    {{/if}}
                </div>
                {{/foreach}}
            </div>
        </section>
        {{/if}}
        {{/get}}
        
        {{!-- Newsletter --}}
        {{> newsletter}}
    </div>
</article>
{{/post}}

