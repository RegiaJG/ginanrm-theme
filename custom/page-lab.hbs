{{!< default}}

{{!-- 
    Custom Page Template: The Lab
    Use this by selecting "lab" in the page template dropdown in Ghost
    For experimental content, projects, and interactive demos
--}}

{{#post}}
<article class="post-full page-lab">
    {{!-- Page Header --}}
    <header class="hero" style="min-height: 40vh; padding-top: calc(var(--header-height) + var(--space-8));">
        <div class="hero-background bg-gradient-sunset">
            <div class="stars"></div>
        </div>
        
        <div class="hero-content">
            <span class="post-header-tag" style="margin-bottom: var(--space-4); background: var(--lc-neon-pink);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display: inline; vertical-align: middle; margin-right: 4px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                </svg>
                The Lab
            </span>
            <h1 class="hero-title" style="font-size: var(--text-2xl);">{{title}}</h1>
            
            {{#if custom_excerpt}}
            <p class="hero-subtitle">{{custom_excerpt}}</p>
            {{else}}
            <p class="hero-subtitle">
                Experimentos, projetos e demos interativos da GinanRM
            </p>
            {{/if}}
        </div>
    </header>
    
    {{!-- Page Content --}}
    <div class="container">
        <section class="post-content gh-content" style="padding-top: var(--space-12);">
            {{content}}
        </section>
        
        {{!-- Lab Projects Posts --}}
        {{#get "posts" filter="tag:lab+tag:projeto" limit="9"}}
        {{#if posts}}
        <section class="posts-section">
            <header class="section-header">
                <h2 class="section-title">Projetos do Lab</h2>
                <a href="{{@site.url}}/tag/lab/" class="btn btn-ghost btn-sm">
                    Ver todos
                </a>
            </header>
            
            <div class="post-grid">
                {{#foreach posts}}
                {{> post-card}}
                {{/foreach}}
            </div>
        </section>
        {{/if}}
        {{/get}}
    </div>
</article>
{{/post}}

