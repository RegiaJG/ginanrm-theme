{{!< default}}

{{#post}}
{{!-- Detecta automaticamente se é página de vendas pelo slug ou tag --}}
{{#match slug "vendas"}}
    {{> page-vendas-template}}
{{else match slug "ebook"}}
    {{> page-vendas-template}}
{{else match slug "comprar"}}
    {{> page-vendas-template}}
{{else match slug "landing"}}
    {{> page-vendas-template}}
{{else match slug "comfyui"}}
    {{> page-vendas-template}}
{{else}}
    {{#has tag="vendas"}}
        {{> page-vendas-template}}
    {{else has tag="ebook"}}
        {{> page-vendas-template}}
    {{else}}
        {{!-- Template padrão de página --}}
        <article class="post-full page-template">
            {{!-- Page Header (respects @page.show_title_and_feature_image setting) --}}
            {{#if @page.show_title_and_feature_image}}
            <header class="post-header">
                <h1 class="post-full-title">{{title}}</h1>
                
                {{#if custom_excerpt}}
                <p class="hero-subtitle" style="max-width: 600px; margin: 0 auto;">
                    {{custom_excerpt}}
                </p>
                {{/if}}
            </header>
            
            {{!-- Feature Image --}}
            {{#if feature_image}}
            <figure class="post-feature-image">
                <img 
                    src="{{img_url feature_image size="xl"}}" 
                    srcset="{{img_url feature_image size="m"}} 600w,
                            {{img_url feature_image size="l"}} 1000w,
                            {{img_url feature_image size="xl"}} 2000w"
                    sizes="(max-width: 1200px) 100vw, 1200px"
                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                >
            </figure>
            {{/if}}
            {{/if}}
            
            {{!-- Page Content --}}
            <section class="post-content gh-content">
                {{content}}
            </section>
        </article>
    {{/has}}
{{/match}}
{{/post}}
