{{!< default}}

{{!-- Hero Section --}}
<section class="hero bg-city{{#match @custom.hero_style "Minimal"}} hero-minimal{{/match}}{{#match @custom.hero_style "With Charlotte"}} hero-with-charlotte{{/match}}">
    {{!-- Background Image (hidden via CSS on Minimal style) --}}
    <div class="hero-background">
        <img 
            src="{{asset "images/hero-city.jpg"}}" 
            alt="GinanRM"
            loading="eager"
        >
        <div class="stars"></div>
    </div>
    
    {{!-- Hero Content --}}
    <div class="hero-content">
        {{!-- Hero Search --}}
        <div class="hero-search">
            <form class="search-form" role="search" action="{{@site.url}}/search/">
                <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input 
                    type="search" 
                    class="search-input" 
                    name="q"
                    placeholder="Buscar posts, tags e autores..."
                    autocomplete="off"
                >
            </form>
        </div>
    </div>
</section>

{{!-- Main Content Area --}}
<div class="container">
    {{!-- Featured Slider --}}
    {{#if @custom.show_featured_slider}}
    {{> featured-slider}}
    {{/if}}
    
    {{!-- Posts Section with Optional Sidebar --}}
    <section class="posts-section">
        <div class="{{#if @custom.show_sidebar}}main-with-sidebar{{/if}}">
            {{!-- Main Content --}}
            <div class="main-content">
                {{!-- Section Header --}}
                <header class="section-header">
                    <h2 class="section-title">Últimos Posts</h2>
                    <a href="{{@site.url}}/page/2/" class="btn btn-ghost btn-sm">
                        Ver todos
                    </a>
                </header>
                
                {{!-- Post Grid --}}
                <div class="post-grid">
                    {{#foreach posts}}
                    {{> post-card}}
                    {{/foreach}}
                </div>
                
                {{!-- Pagination --}}
                {{> pagination}}
            </div>
            
            {{!-- Sidebar --}}
            {{#if @custom.show_sidebar}}
            {{> sidebar}}
            {{/if}}
        </div>
    </section>
    
    {{!-- Newsletter Section --}}
    {{> newsletter}}
</div>

