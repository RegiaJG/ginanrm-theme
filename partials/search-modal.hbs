<div class="search-modal" id="search-modal" role="dialog" aria-modal="true" aria-label="Busca">
    {{!-- Close Button --}}
    <button class="search-modal-close" aria-label="Fechar busca" data-search-close>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
    </button>
    
    {{!-- Search Content --}}
    <div class="search-modal-content">
        <form class="search-form" role="search" action="{{@site.url}}/search/">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input 
                type="search" 
                class="search-input" 
                name="q"
                placeholder="Buscar posts, tags e autores..."
                autocomplete="off"
                data-search-modal-input
            >
        </form>
        
        {{!-- Search Results Container --}}
        <div class="search-results" id="search-results" style="margin-top: var(--space-6);">
            {{!-- Results will be injected here by JavaScript --}}
        </div>
        
        {{!-- Search Tips --}}
        <div class="search-tips" style="margin-top: var(--space-8); text-align: center;">
            <p style="font-size: var(--text-sm); color: var(--lc-gray-500);">
                Pressione <kbd style="padding: 2px 8px; background: var(--color-surface); border-radius: 4px; font-family: var(--font-mono);">ESC</kbd> para fechar
            </p>
        </div>
    </div>
</div>

