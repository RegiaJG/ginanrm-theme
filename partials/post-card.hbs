<article class="post-card{{#if featured}} post-card-featured{{/if}}">
    <a href="{{url}}" class="post-card-image-link">
        <div class="post-card-image">
            {{#if feature_image}}
            <img 
                src="{{img_url feature_image size="m"}}" 
                srcset="{{img_url feature_image size="s"}} 300w,
                        {{img_url feature_image size="m"}} 600w,
                        {{img_url feature_image size="l"}} 1000w"
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                loading="lazy"
            >
            {{else}}
            <img 
                src="{{asset "images/placeholder.jpg"}}" 
                alt="{{title}}"
                loading="lazy"
            >
            {{/if}}
            
            {{!-- Primary Tag --}}
            {{#if primary_tag}}
            <span class="post-card-tag">{{primary_tag.name}}</span>
            {{/if}}
        </div>
    </a>
    
    <div class="post-card-content">
        <a href="{{url}}">
            <h2 class="post-card-title">{{title}}</h2>
        </a>
        
        {{#if excerpt}}
        <p class="post-card-excerpt">{{excerpt words="25"}}</p>
        {{/if}}
        
        <div class="post-card-meta">
            {{#if primary_author.profile_image}}
            <img 
                src="{{img_url primary_author.profile_image size="xs"}}" 
                alt="{{primary_author.name}}" 
                class="post-card-author-image"
                loading="lazy"
            >
            {{/if}}
            <span>{{primary_author.name}}</span>
            <span>&bull;</span>
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
            {{#if reading_time}}
            <span>&bull;</span>
            <span>{{reading_time}} min de leitura</span>
            {{/if}}
        </div>
    </div>
</article>

